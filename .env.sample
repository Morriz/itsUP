# uncomment in your prod env to make the repo update itself via webhook:
# PYTHON_ENV=production

# Root directory of itsUP installation (needed for OpenSnitch rules)
# Should be the absolute path to this directory
ITSUP_ROOT=$HOME/itsup

# Container host identity for host-only runtime commands.
# Set to this host's own LAN IP; itsUP compares it to the detected LAN IP.
# SSH_HOST=192.168.1.10

# Domain suffix for all tls services that don't specify their own
DOMAIN_SUFFIX=example.com
# Traefik dashboard domain name
TRAEFIK_DOMAIN=traefik.$DOMAIN_SUFFIX
# Traefic basic auth user+pass (htpasswd) WHICH NEEDS TO BE QUOTED!
# TRAEFIK_ADMIN='admin:$xxx/yyy'

# Letsencrypt settings
LETSENCRYPT_EMAIL=admin@example.com
# Uncomment next line for prod certs:
LETSENCRYPT_STAGING=1

# Main api key for itsUP
API_KEY=

# AbuseIPDB API key for threat intelligence (get free key at https://www.abuseipdb.com/register)
# Free tier: 1,000 checks/day
ABUSEIPDB_API_KEY=

# OpenSnitch database path for container security monitor
OPENSNITCH_DB=/var/lib/opensnitch/opensnitch.sqlite3
