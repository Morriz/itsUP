client
nobind
dev tun
remote-cert-tls server

cipher AES-256-GCM

# ca, cert, client key, and tls-auth are injected at deploy time from the
# OVPN_CA / OVPN_CERT / OVPN_USER_KEY / OVPN_TLS_AUTH_KEY GitHub secrets by
# Morriz/github-openvpn-connect-action — not embedded here, so the secrets are
# the single source of truth and no stale cert can drift into the repo.

key-direction 1

redirect-gateway def1
