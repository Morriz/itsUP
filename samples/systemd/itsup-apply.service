[Unit]
Description=Nightly itsUP apply (regen + deploy all stacks/projects)
After=network-online.target docker.service
Requires=docker.service
OnFailure=itsup-alert@%n.service

[Service]
Type=oneshot
User={{USER}}
Group={{GROUP}}
StateDirectory=itsup
WorkingDirectory={{ROOT}}
Environment=HOME=/home/{{USER}}
Environment=ITSUP_ROOT={{ROOT}}
ExecStart={{ROOT}}/.venv/bin/itsup apply
ExecStartPost=/bin/sh -c 'touch "$STATE_DIRECTORY/apply-success"'
