[Unit]
Description=Periodic health check with auto-recovery
After=network-online.target docker.service
Requires=docker.service
OnFailure=itsup-alert@%n.service

[Service]
Type=oneshot
User={{USER}}
Group={{GROUP}}
RuntimeDirectory=itsup
RuntimeDirectoryPreserve=yes
WorkingDirectory={{ROOT}}
Environment=HOME=/home/{{USER}}
Environment=ITSUP_ROOT={{ROOT}}
ExecStart={{ROOT}}/bin/pi-healthcheck.sh
