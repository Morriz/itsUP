#!/usr/bin/env python3

"""itsUP CLI shim.

Thin launcher that lets ``bin/itsup …`` work without an editable install: it
puts the repo root on ``sys.path`` so the ``itsup`` package imports, then
delegates to the single CLI source in ``itsup/cli.py``. The packaged console
script (``pyproject.toml`` ``[project.scripts]``) needs no path insert.
"""

import os
import sys
from pathlib import Path

_SCRIPT = Path(__file__).resolve()
_ROOT = _SCRIPT.parent.parent
_VENV = _ROOT / ".venv"
_VENV_PYTHON = _VENV / "bin" / "python"

if __name__ == "__main__" and _VENV_PYTHON.exists() and Path(sys.prefix).resolve() != _VENV.resolve():
    os.execv(str(_VENV_PYTHON), [str(_VENV_PYTHON), str(_SCRIPT), *sys.argv[1:]])

# itsup is in bin/, so the repo root is the parent of bin/.
sys.path.insert(0, str(_ROOT))

from itsup.cli import main

if __name__ == "__main__":
    main()
